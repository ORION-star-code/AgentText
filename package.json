{
  "name": "codeinsight-agent",
  "version": "0.1.0",
  "description": "CodeInsight Agent - 真实代码仓库理解助手",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "codeinsight": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "prebuild": "rm -rf dist",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write src/ tests/",
    "check": "tsc --noEmit",
    "clean": "rm -rf dist coverage .codeinsight",
    "prepare": "husky"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "code-analysis",
    "ai-agent",
    "repository-understanding",
    "claude"
  ],
  "author": "ORION",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@octokit/rest": "^21.1.1",
    "chalk": "^5.6.2",
    "commander": "^13.1.0",
    "ignore": "^7.0.3",
    "ora": "^9.4.0",
    "simple-git": "^3.27.0",
    "ts-morph": "^25.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@types/node": "^22.15.2",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.25.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "tests/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
