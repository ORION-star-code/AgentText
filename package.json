{
  "name": "codeinsight-agent",
  "version": "0.1.0",
  "description": "CodeInsight Agent - 真实代码仓库理解助手",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "codeinsight": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write src/ tests/",
    "check": "tsc --noEmit"
  },
  "keywords": ["code-analysis", "ai-agent", "repository-understanding", "claude"],
  "author": "ORION",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "commander": "^13.1.0",
    "simple-git": "^3.27.0",
    "@octokit/rest": "^21.1.1",
    "ts-morph": "^25.0.1",
    "ignore": "^7.0.3"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.1.1",
    "@types/node": "^22.15.2",
    "tsx": "^4.19.4",
    "eslint": "^9.25.1",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "prettier": "^3.5.3"
  }
}
